<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Left sidebar navigation -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="260dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingTop="40dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎬 DualSub TV"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:paddingBottom="32dp"/>

        <Button
            android:id="@+id/navPlaylists"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📋  Mis Listas"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/primary"
            android:gravity="start|center_vertical"
            android:paddingStart="24dp"
            android:textSize="16sp"
            style="?attr/borderlessButtonStyle"/>

        <Button
            android:id="@+id/navDirectPlay"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  Reproducir URL"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@android:color/transparent"
            android:gravity="start|center_vertical"
            android:paddingStart="24dp"
            android:textSize="16sp"
            style="?attr/borderlessButtonStyle"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/background"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>

        <Button
            android:id="@+id/navAddPlaylist"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="➕  Agregar Lista"
            android:textColor="@color/accent"
            android:backgroundTint="@android:color/transparent"
            android:gravity="start|center_vertical"
            android:paddingStart="24dp"
            android:textSize="16sp"
            style="?attr/borderlessButtonStyle"/>
    </LinearLayout>

    <!-- Main content area -->
    <FrameLayout
        android:id="@+id/contentArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

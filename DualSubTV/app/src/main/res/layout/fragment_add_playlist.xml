<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="32dp"
    android:background="@color/background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvAddTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="➕ Agregar Lista M3U"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:paddingBottom="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Playlist name -->
        <TextView
            android:id="@+id/labelName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nombre de la lista"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvAddTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etPlaylistName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Ej: Mi IPTV"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/primary"
            android:padding="12dp"
            android:textSize="16sp"
            android:inputType="text"
            android:imeOptions="actionNext"
            app:layout_constraintTop_toBottomOf="@id/labelName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Source type selector -->
        <RadioGroup
            android:id="@+id/rgSourceType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/etPlaylistName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/rbUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌐  URL online"
                android:textColor="@color/text_primary"
                android:checked="true"
                android:paddingEnd="24dp"/>

            <RadioButton
                android:id="@+id/rbLocalFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁  Archivo local"
                android:textColor="@color/text_primary"/>
        </RadioGroup>

        <!-- URL input -->
        <EditText
            android:id="@+id/etPlaylistUrl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="http://tu-servidor.com/lista.m3u"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/primary"
            android:padding="12dp"
            android:textSize="16sp"
            android:inputType="textUri"
            app:layout_constraintTop_toBottomOf="@id/rgSourceType"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Local file picker button -->
        <Button
            android:id="@+id/btnPickFile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📂  Seleccionar archivo .m3u"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/surface"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/rgSourceType"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvSelectedFile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            android:paddingTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnPickFile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Save button -->
        <Button
            android:id="@+id/btnSavePlaylist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💾  GUARDAR LISTA"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/primary"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/etPlaylistUrl"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ProgressBar
            android:id="@+id/progressSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/primary"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnSavePlaylist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvSaveStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/progressSave"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

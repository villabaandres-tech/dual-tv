<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="48dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="🎬 DualSub TV"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Reproductor con doble subtítulo"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:paddingBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Video URL / Path -->
        <TextView
            android:id="@+id/labelVideo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="📹  URL del video o ruta local"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etVideoUrl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/url_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/primary"
            android:padding="12dp"
            android:textSize="16sp"
            android:inputType="textUri"
            android:imeOptions="actionNext"
            android:nextFocusDown="@+id/etSub1"
            app:layout_constraintTop_toBottomOf="@id/labelVideo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Divider -->
        <View
            android:id="@+id/divider1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/surface"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/etVideoUrl"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Subtitle 1 Section -->
        <TextView
            android:id="@+id/labelSub1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="🔤  Subtítulo 1 (arriba)"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/divider1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Sub1 Type Selector -->
        <RadioGroup
            android:id="@+id/rgSub1Type"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelSub1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/rbSub1None"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ninguno"
                android:textColor="@color/text_primary"
                android:checked="true"
                android:paddingEnd="16dp"/>

            <RadioButton
                android:id="@+id/rbSub1Embedded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incrustado"
                android:textColor="@color/text_primary"
                android:paddingEnd="16dp"/>

            <RadioButton
                android:id="@+id/rbSub1External"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Archivo externo"
                android:textColor="@color/text_primary"/>
        </RadioGroup>

        <EditText
            android:id="@+id/etSub1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/sub1_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/primary"
            android:padding="12dp"
            android:textSize="16sp"
            android:inputType="textUri"
            android:imeOptions="actionNext"
            android:nextFocusDown="@+id/etSub2"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/rgSub1Type"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Embedded sub1 track selector -->
        <LinearLayout
            android:id="@+id/layoutSub1EmbeddedSelector"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/rgSub1Type"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pista:"
                android:textColor="@color/text_secondary"
                android:paddingEnd="8dp"/>

            <Spinner
                android:id="@+id/spinnerSub1Track"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary"/>
        </LinearLayout>

        <!-- Divider 2 -->
        <View
            android:id="@+id/divider2"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/surface"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/etSub1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Subtitle 2 Section -->
        <TextView
            android:id="@+id/labelSub2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="🔡  Subtítulo 2 (abajo)"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/divider2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <RadioGroup
            android:id="@+id/rgSub2Type"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelSub2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/rbSub2None"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ninguno"
                android:textColor="@color/text_primary"
                android:checked="true"
                android:paddingEnd="16dp"/>

            <RadioButton
                android:id="@+id/rbSub2Embedded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incrustado"
                android:textColor="@color/text_primary"
                android:paddingEnd="16dp"/>

            <RadioButton
                android:id="@+id/rbSub2External"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Archivo externo"
                android:textColor="@color/text_primary"/>
        </RadioGroup>

        <EditText
            android:id="@+id/etSub2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/sub2_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/primary"
            android:padding="12dp"
            android:textSize="16sp"
            android:inputType="textUri"
            android:imeOptions="actionDone"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/rgSub2Type"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:id="@+id/layoutSub2EmbeddedSelector"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/rgSub2Type"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pista:"
                android:textColor="@color/text_secondary"
                android:paddingEnd="8dp"/>

            <Spinner
                android:id="@+id/spinnerSub2Track"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary"/>
        </LinearLayout>

        <!-- Play Button -->
        <Button
            android:id="@+id/btnPlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶  REPRODUCIR"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/primary"
            android:paddingStart="48dp"
            android:paddingEnd="48dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/etSub2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

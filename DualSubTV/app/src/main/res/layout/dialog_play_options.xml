<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="28dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="▶ Reproducir"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvEntryName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:paddingBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvDialogTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Sub 1 -->
        <TextView
            android:id="@+id/labelDSub1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="🔤 Subtítulo 1 (arriba, blanco)"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvEntryName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <RadioGroup
            android:id="@+id/rgDSub1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="6dp"
            app:layout_constraintTop_toBottomOf="@id/labelDSub1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton android:id="@+id/rbD1None"     android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ninguno"   android:textColor="@color/text_primary" android:checked="true" android:paddingEnd="16dp"/>
            <RadioButton android:id="@+id/rbD1Embedded" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Incrustado" android:textColor="@color/text_primary" android:paddingEnd="16dp"/>
            <RadioButton android:id="@+id/rbD1External" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Archivo externo" android:textColor="@color/text_primary"/>
        </RadioGroup>

        <EditText
            android:id="@+id/etDSub1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="URL o ruta del subtítulo 1"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/primary"
            android:padding="10dp"
            android:textSize="14sp"
            android:inputType="textUri"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/rgDSub1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Sub 2 -->
        <TextView
            android:id="@+id/labelDSub2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="🔡 Subtítulo 2 (abajo, amarillo)"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/etDSub1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <RadioGroup
            android:id="@+id/rgDSub2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="6dp"
            app:layout_constraintTop_toBottomOf="@id/labelDSub2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton android:id="@+id/rbD2None"     android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ninguno"   android:textColor="@color/text_primary" android:checked="true" android:paddingEnd="16dp"/>
            <RadioButton android:id="@+id/rbD2Embedded" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Incrustado" android:textColor="@color/text_primary" android:paddingEnd="16dp"/>
            <RadioButton android:id="@+id/rbD2External" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Archivo externo" android:textColor="@color/text_primary"/>
        </RadioGroup>

        <EditText
            android:id="@+id/etDSub2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="URL o ruta del subtítulo 2"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/primary"
            android:padding="10dp"
            android:textSize="14sp"
            android:inputType="textUri"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/rgDSub2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Action buttons -->
        <LinearLayout
            android:id="@+id/dialogButtons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:paddingTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/etDSub2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnDialogCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancelar"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@android:color/transparent"
                android:layout_marginEnd="16dp"
                style="?attr/borderlessButtonStyle"/>

            <Button
                android:id="@+id/btnDialogPlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶  REPRODUCIR"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/primary"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
